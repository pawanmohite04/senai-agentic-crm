  "components": {
    "schemas": {
      "ContactOut": {
        "properties": {
          "email": {
            "type": "string",
            "title": "Email"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "company": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Company"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "account_value": {
            "type": "number",
            "title": "Account Value"
          },
          "churn_risk_score": {
            "type": "number",
            "title": "Churn Risk Score"
          },
          "open_threads": {
            "type": "integer",
            "title": "Open Threads",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "email",
          "name",
          "company",
          "status",
          "account_value",
          "churn_risk_score"
        ],
        "title": "ContactOut"
      },
      "DraftUpdate": {
        "properties": {
          "proposed_content": {
            "type": "string",
            "title": "Proposed Content"
          }
        },
        "type": "object",
        "required": [
          "proposed_content"
        ],
        "title": "DraftUpdate"
      },
      "EmailIn": {
        "properties": {
          "message_id": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Message Id"
          },
          "sender": {
            "type": "string",
            "format": "email",
            "title": "Sender"
          },
          "subject": {
            "type": "string",
            "title": "Subject",
            "default": ""
          },
          "body": {
            "type": "string",
            "title": "Body",
            "default": ""
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "thread_id": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Thread Id"
          }
        },
        "type": "object",
        "required": [
          "message_id",
          "sender",
          "timestamp",
          "thread_id"
        ],
        "title": "EmailIn"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IngestResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "email_id": {
            "type": "integer",
            "title": "Email Id"
          },
          "duplicate": {
            "type": "boolean",
            "title": "Duplicate"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "priority_score": {
            "type": "number",
            "title": "Priority Score"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "email_id",
          "duplicate",
          "status",
          "priority_score"
        ],
        "title": "IngestResponse"
      },
      "ReplyRequest": {
        "properties": {
          "body": {
            "type": "string",
            "title": "Body"
          },
          "approved_by": {
            "type": "string",
            "title": "Approved By",
            "default": "user"
          }
        },
        "type": "object",
        "required": [
          "body"
        ],
        "title": "ReplyRequest"
      },
      "StatusUpdate": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "VIP",
              "Blocked",
              "Active",
              "Churned"
            ],
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "StatusUpdate"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}